int currentNote = 0;  // 次に送信する音を指定する変数
unsigned long startTime = 0;  // 開始時刻
unsigned long beat = 0;  // 1拍の時間（ms）
float BPM = 120.0;  // BPM

void setup() {
  Serial.begin(115200);

  // BPMから1拍を計算
  beat = 60000 / BPM;
  // 開始時刻を記録
  startTime = millis();
}

void loop() {
  // 楽譜のデータが残っている場合
  if (currentNote < sizeof(note)/sizeof(note[0])) {
    
    // 現在の経過時間を計算
    unsigned long elapsedTime = millis() - startTime;

    // タイミングに1拍をかけた値分経過していたら送信
    if (elapsedTime >= (time[currentNote] * beat)) {
      
      // データを送信（BPM, 音階, 長さ）
      Serial.print(BPM);
      Serial.print(",");
      Serial.print(note[currentNote]);
      Serial.print(",");
      Serial.println(duration[currentNote]);

      // 次の音へ
      currentNote++;
    }
  }
}